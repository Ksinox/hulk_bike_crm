# Скопируй в .env и поправь под свою машину.
# В prod (Dokploy) эти переменные задаются через UI.

# Подключение к Postgres
DATABASE_URL=postgres://hulk:hulk@localhost:5433/hulk_dev

# На чём слушать
PORT=4000
HOST=0.0.0.0

# Окружение: development | staging | production
NODE_ENV=development

# Список доменов, которым разрешён CORS (через запятую).
# В dev фронт ходит с http://localhost:5173
CORS_ORIGINS=http://localhost:5173
