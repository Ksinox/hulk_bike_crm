# Скопируй в .env и поправь под свою машину.
# В prod (Dokploy) эти переменные задаются через UI.

# Подключение к Postgres
DATABASE_URL=postgres://hulk:hulk@localhost:5433/hulk_dev

# На чём слушать
PORT=4000
HOST=0.0.0.0

# Окружение: development | staging | production
NODE_ENV=development

# Список доменов, которым разрешён CORS (через запятую).
# В dev фронт ходит с http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ---- MinIO (S3-совместимое хранилище файлов) ----
# В dev-compose: endpoint=minio (имя сервиса), но если api запускается локально
# без docker — endpoint=localhost и поправь порт на тот что в compose (9000).
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=hulkminio
S3_SECRET_KEY=hulkminio_dev_password
S3_BUCKET=hulk-docs

# ---- Auth ----
# Секрет для подписи JWT. В prod обязательно задать уникальное длинное значение.
JWT_SECRET=dev-only-hulk-jwt-secret-change-me-in-production

# Комбинация клавиш на экране входа, открывающая скрытый тайл creator'а.
# Можно менять на проде через env — код клиента читает её при загрузке /login.
CREATOR_UNLOCK_SEQUENCE=ksinox

# ---- Seed паролей (используется только при запуске pnpm db:seed) ----
# Пароли для трёх стартовых юзеров. В git не коммитятся — берутся из env.
SEED_CREATOR_PASSWORD=
SEED_DIRECTOR_PASSWORD=
SEED_ADMIN_PASSWORD=
